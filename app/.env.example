# Security / production hardening
AUTH_DEBUG_TOKENS=0
NEXTAUTH_SECRET=change-me-in-prod
INTERNAL_BASE_URL=http://localhost:3000
PUBLIC_APP_ORIGIN=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
INTERNAL_API_TOKEN=change-me-in-prod
ALLOW_INSECURE_INTERNAL_CALLS=0
CSP_MODE=off
CSP_REPORT_URI=
AUTH_SESSION_INVALIDATE_BEFORE=
PUBLIC_ASSET_BASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Notifications
CRON_SECRET=
EMAIL_PROVIDER=console
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_API_URL=
NOTIFICATIONS_UNSUBSCRIBE_SECRET=
# Unsubscribe token signing (active + optional previous secret for rotation)
HMAC_SECRET_CURRENT=
HMAC_SECRET_PREVIOUS=
UNSUBSCRIBE_TOKEN_TTL_SECONDS=2592000
