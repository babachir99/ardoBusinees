# Staging / preview baseline
NODE_ENV=production
NEXTAUTH_URL=https://staging.jontaado.example
PUBLIC_APP_ORIGIN=https://staging.jontaado.example
INTERNAL_BASE_URL=https://staging.jontaado.example
ALLOWED_HOSTS=staging.jontaado.example
INTERNAL_API_TOKEN=replace-with-long-random-secret
NEXTAUTH_SECRET=replace-with-long-random-secret
ALLOW_INSECURE_INTERNAL_CALLS=0
AUTH_DEBUG_TOKENS=0

# Progressive CSP rollout
CSP_MODE=report-only
CSP_REPORT_URI=https://csp-report-collector.example/report
AUTH_SESSION_INVALIDATE_BEFORE=

# Assets / notifications / webhooks
PUBLIC_ASSET_BASE_URL=
PAYDUNYA_WEBHOOK_SECRET=
PAYMENTS_CALLBACK_TOKEN=
CRON_SECRET=
EMAIL_PROVIDER=console
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_API_URL=
NOTIFICATIONS_UNSUBSCRIBE_SECRET=
HMAC_SECRET_CURRENT=
HMAC_SECRET_PREVIOUS=
UNSUBSCRIBE_TOKEN_TTL_SECONDS=2592000

# Optional distributed rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
