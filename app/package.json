{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "qa:env:staging": "node scripts/check-security-env.mjs",
    "verify": "npm run lint && npm run typecheck && npm run qa:auth && npm run qa:kyc && npm run qa:forms-prefill && npm run build",
    "seed": "prisma db seed",
    "postinstall": "prisma generate",
    "fix:product-slugs": "node scripts/fix-product-slugs.js",
    "qa:seed-auth-fixtures": "node scripts/seed-auth-fixtures.js",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:smoke:readonly": "node scripts/qa-smoke.mjs --readonly",
    "qa:auth": "node scripts/qa-auth-routes.mjs",
    "qa:notifications": "node scripts/qa-notifications.mjs",
    "qa:notifications:invariants": "node scripts/qa-notifications.mjs",
    "qa:kyc": "node scripts/qa-kyc-requirements.mjs",
    "qa:forms-prefill": "node scripts/qa-forms-prefill.mjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "next": "^16.2.3",
    "next-auth": "^4.24.13",
    "next-intl": "^4.9.1",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
