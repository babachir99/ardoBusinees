// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SELLER
  CUSTOMER
  TRANSPORTER
  COURIER
}

enum SellerStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum ProductType {
  PREORDER
  DROPSHIP
  LOCAL
}

enum StoreType {
  MARKETPLACE
  IMMO
  CARS
  PRESTA
  TIAK_TIAK
  GP
}

enum BoostStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  FULFILLING
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  WAVE
  ORANGE_MONEY
  CARD
  CASH
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycRole {
  SELLER
  TRANSPORTER
  COURIER
}

enum InquiryStatus {
  OPEN
  CLOSED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
  EXPIRED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  phone         String?
  locale        String    @default("fr")
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  activityLogs    ActivityLog[]
  kycSubmissions  KycSubmission[]
  sellerProfile   SellerProfile?
  orders          Order[]
  bookings        ServiceBooking[]
  favorites       Favorite[]
  orderMessages   OrderMessage[]
  buyerInquiries  ProductInquiry[]        @relation("InquiryBuyer")
  inquiryMessages ProductInquiryMessage[]
  offersMade      ProductOffer[]          @relation("OfferBuyer")
  productReviews  ProductReview[]         @relation("ProductReviewBuyer")
}

model SellerProfile {
  id               String       @id @default(cuid())
  userId           String       @unique
  displayName      String
  slug             String       @unique
  status           SellerStatus @default(PENDING)
  commissionRate   Int          @default(10)
  payoutAccountRef String?
  rating           Float        @default(5)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user      User             @relation(fields: [userId], references: [id])
  products  Product[]
  orders    Order[]
  payouts   Payout[]
  services  ServiceListing[]
  inquiries ProductInquiry[] @relation("InquirySeller")
  offers    ProductOffer[]   @relation("OfferSeller")
  reviews   ProductReview[]
}

model Product {
  id               String      @id @default(cuid())
  sellerId         String
  storeId          String?
  title            String
  slug             String
  description      String?
  priceCents       Int
  currency         String      @default("XOF")
  type             ProductType
  preorderLeadDays Int?
  dropshipSupplier String?
  stockQuantity    Int?        @default(0)
  pickupLocation   String?
  deliveryOptions  String?
  isActive         Boolean     @default(true)
  discountPercent  Int?
  boostStatus      BoostStatus @default(NONE)
  boostRequestedAt DateTime?
  boostedUntil     DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  seller     SellerProfile     @relation(fields: [sellerId], references: [id])
  store      Store?            @relation(fields: [storeId], references: [id])
  images     ProductImage[]
  orderItems OrderItem[]
  categories ProductCategory[]
  favorites  Favorite[]
  inquiries  ProductInquiry[]
  offers     ProductOffer[]
  reviews    ProductReview[]

  @@unique([sellerId, slug])
  @@index([sellerId])
  @@index([storeId])
}

model Store {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  type        StoreType @default(MARKETPLACE)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]        @relation("CategoryTree")
  products ProductCategory[]
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Order {
  id              String         @id @default(cuid())
  userId          String
  sellerId        String?
  buyerName       String?
  buyerEmail      String?
  buyerPhone      String?
  shippingAddress String?
  shippingCity    String?
  paymentMethod   PaymentMethod?
  status          OrderStatus    @default(PENDING)
  subtotalCents   Int
  shippingCents   Int            @default(0)
  feesCents       Int            @default(0)
  totalCents      Int
  currency        String         @default("XOF")
  paymentStatus   PaymentStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  seller   SellerProfile? @relation(fields: [sellerId], references: [id])
  items    OrderItem[]
  payment  Payment?
  payouts  Payout[]
  events   OrderEvent[]
  messages OrderMessage[]

  @@index([userId])
  @@index([sellerId])
  @@index([buyerEmail])
}

model OrderMessage {
  id         String    @id @default(cuid())
  orderId    String
  senderId   String?
  senderRole UserRole?
  body       String
  createdAt  DateTime  @default(now())

  order  Order @relation(fields: [orderId], references: [id])
  sender User? @relation(fields: [senderId], references: [id])

  @@index([orderId])
  @@index([senderId])
}

model OrderItem {
  id             String      @id @default(cuid())
  orderId        String
  productId      String
  quantity       Int         @default(1)
  unitPriceCents Int
  type           ProductType
  optionColor    String?
  optionSize     String?
  createdAt      DateTime    @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id          String         @id @default(cuid())
  orderId     String         @unique
  provider    String         @default("paydunya")
  providerRef String?
  amountCents Int
  currency    String         @default("XOF")
  status      PaymentStatus  @default(PENDING)
  method      PaymentMethod?
  splitMeta   Json?
  createdAt   DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model Payout {
  id          String       @id @default(cuid())
  sellerId    String
  orderId     String?
  amountCents Int
  currency    String       @default("XOF")
  status      PayoutStatus @default(PENDING)
  providerRef String?
  createdAt   DateTime     @default(now())

  seller SellerProfile @relation(fields: [sellerId], references: [id])
  order  Order?        @relation(fields: [orderId], references: [id])

  @@index([sellerId])
  @@index([orderId])
}

model ServiceListing {
  id          String   @id @default(cuid())
  sellerId    String
  title       String
  description String?
  priceCents  Int
  currency    String   @default("XOF")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller   SellerProfile    @relation(fields: [sellerId], references: [id])
  bookings ServiceBooking[]

  @@index([sellerId])
}

model ServiceBooking {
  id          String        @id @default(cuid())
  serviceId   String
  customerId  String
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime?
  priceCents  Int
  currency    String        @default("XOF")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  service  ServiceListing @relation(fields: [serviceId], references: [id])
  customer User           @relation(fields: [customerId], references: [id])

  @@index([serviceId])
  @@index([customerId])
}

model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  proofUrl  String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
}

model ProductReview {
  id           String   @id @default(cuid())
  productId    String
  sellerId     String
  buyerId      String
  rating       Int
  sellerRating Int?
  title        String?
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller  SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyer   User          @relation("ProductReviewBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([productId, buyerId])
  @@index([productId, createdAt])
  @@index([sellerId, createdAt])
  @@index([buyerId, createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model KycSubmission {
  id               String    @id @default(cuid())
  userId           String
  targetRole       KycRole
  status           KycStatus @default(PENDING)
  docIdUrl         String?
  driverLicenseUrl String?
  proofAddressUrl  String?
  selfieUrl        String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([targetRole])
}

model ProductInquiry {
  id               String         @id @default(cuid())
  productId        String
  buyerId          String
  sellerId         String
  status           InquiryStatus  @default(OPEN)
  lastMessageAt    DateTime       @default(now())
  buyerLastReadAt  DateTime?
  sellerLastReadAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  product  Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer    User                    @relation("InquiryBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   SellerProfile           @relation("InquirySeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages ProductInquiryMessage[]
  offers   ProductOffer[]

  @@unique([productId, buyerId])
  @@index([sellerId, status, lastMessageAt])
  @@index([buyerId, status, lastMessageAt])
}

model ProductInquiryMessage {
  id        String   @id @default(cuid())
  inquiryId String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  inquiry ProductInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  sender  User           @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
  @@index([senderId])
}

model ProductOffer {
  id          String      @id @default(cuid())
  inquiryId   String
  productId   String
  buyerId     String
  sellerId    String
  quantity    Int         @default(1)
  amountCents Int
  currency    String      @default("XOF")
  note        String?
  status      OfferStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  resolvedAt  DateTime?

  inquiry ProductInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   User           @relation("OfferBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller  SellerProfile  @relation("OfferSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
  @@index([sellerId, status, createdAt])
  @@index([buyerId, status, createdAt])
}


