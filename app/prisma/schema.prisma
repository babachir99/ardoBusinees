// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SELLER
  CUSTOMER
  TRANSPORTER
  COURIER
}

enum UserRoleType {
  CLIENT
  SELLER
  PRESTA_PROVIDER
  GP_CARRIER
  TIAK_COURIER
  IMMO_AGENT
  ADMIN
}

enum UserRoleStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum SellerStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum ProductType {
  PREORDER
  DROPSHIP
  LOCAL
}

enum StoreType {
  MARKETPLACE
  IMMO
  CARS
  PRESTA
  TIAK_TIAK
  GP
}

enum BoostStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  FULFILLING
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  WAVE
  ORANGE_MONEY
  CARD
  CASH
}

enum PayoutStatus {
  PENDING
  HOLD
  PAID
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycRole {
  SELLER
  TRANSPORTER
  COURIER
}

enum GpTripStatus {
  OPEN
  CLOSED
  CANCELED
}

enum GpBookingStatus {
  DRAFT
  PENDING
  ACCEPTED
  CONFIRMED
  COMPLETED
  DELIVERED
  CANCELED
  REJECTED
}

enum GpShipmentStatus {
  DROPPED_OFF
  PICKED_UP
  BOARDED
  ARRIVED
  DELIVERED
}

enum PrestaBookingStatus {
  PENDING
  CONFIRMED
  PAID
  COMPLETED
  CANCELED
  REJECTED
}

enum PrestaNeedStatus {
  OPEN
  IN_REVIEW
  ACCEPTED
  CLOSED
  CANCELED
}

enum PrestaProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PrestaPayoutStatus {
  PENDING
  READY
  PAID
  FAILED
}

enum TiakPayoutStatus {
  PENDING
  READY
  PAID
  FAILED
}

enum PaymentLedgerContextType {
  SHOP_ORDER
  PRESTA_BOOKING
  TIAK_DELIVERY
  IMMO_MONETIZATION
}

enum PaymentLedgerStatus {
  INITIATED
  CONFIRMED
  FAILED
}

enum TiakDeliveryStatus {
  REQUESTED
  ASSIGNED
  ACCEPTED
  PICKED_UP
  DELIVERED
  COMPLETED
  CANCELED
  REJECTED
}

enum InquiryStatus {
  OPEN
  CLOSED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
  EXPIRED
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum DisputeContextType {
  SHOP_ORDER
  PRESTA_BOOKING
  TIAK_DELIVERY
  GP_SHIPMENT
}

enum ImmoListingType {
  SALE
  RENT
}

enum ImmoPropertyType {
  APARTMENT
  HOUSE
  LAND
  COMMERCIAL
  OTHER
}

enum ImmoListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum ImmoContactMode {
  INTERNAL_MESSAGE
}

enum ImmoPublisherType {
  INDIVIDUAL
  AGENCY
}

enum ImmoPublisherMemberRole {
  OWNER
  AGENT
}

enum ImmoPublisherStatus {
  ACTIVE
  SUSPENDED
}

enum ImmoMonetizationKind {
  FEATURED
  BOOST
}

enum ImmoMonetizationPurchaseStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String?
  image                  String?
  emailVerified          DateTime?
  passwordHash           String?
  phone                  String?
  locale                 String    @default("fr")
  role                   UserRole  @default(CUSTOMER)
  isActive               Boolean   @default(true)
  transporterRating      Float     @default(5)
  transporterReviewCount Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  accounts                   Account[]
  sessions                   Session[]
  roleAssignments            UserRoleAssignment[]
  activityLogs               ActivityLog[]
  kycSubmissions             KycSubmission[]         @relation("KycSubmissionUser")
  kycReviewedSubmissions     KycSubmission[]         @relation("KycReviewedBy")
  sellerProfile              SellerProfile?
  orders                     Order[]
  bookings                   ServiceBooking[]
  addresses                  UserAddress[]
  cart                       UserCart?
  favorites                  Favorite[]
  orderMessages              OrderMessage[]
  buyerInquiries             ProductInquiry[]        @relation("InquiryBuyer")
  inquiryMessages            ProductInquiryMessage[]
  offersMade                 ProductOffer[]          @relation("OfferBuyer")
  productReviews             ProductReview[]         @relation("ProductReviewBuyer")
  gpTrips                    GpTrip[]
  gpBookingsAsCustomer       GpTripBooking[]         @relation("GpBookingCustomer")
  gpBookingsAsTransporter    GpTripBooking[]         @relation("GpBookingTransporter")
  gpShipmentsAsSender        GpShipment[]            @relation("GpShipmentSender")
  gpShipmentsAsReceiver      GpShipment[]            @relation("GpShipmentReceiver")
  gpShipmentsAsTransporter   GpShipment[]            @relation("GpShipmentTransporter")
  gpShipmentEvents           GpShipmentEvent[]       @relation("GpShipmentEventActor")
  transporterReviewsReceived TransporterReview[]     @relation("TransporterReviewTransporter")
  transporterReviewsGiven    TransporterReview[]     @relation("TransporterReviewAuthor")
  prestaServices             PrestaService[]
  prestaBookingsAsCustomer   PrestaBooking[]         @relation("PrestaBookingCustomer")
  prestaBookingsAsProvider   PrestaBooking[]         @relation("PrestaBookingProvider")
  prestaPayouts              PrestaPayout[]
  prestaNeeds                PrestaNeed[]            @relation("PrestaNeedCustomer")
  prestaProposals            PrestaProposal[]        @relation("PrestaProposalProvider")
  prestaReviewsAuthored      Review[]                @relation("PrestaReviewAuthor")
  prestaReviewsReceived      Review[]                @relation("PrestaReviewTarget")
  disputesOpened             Dispute[]             @relation("DisputeOpenedBy")
  disputesAssigned           Dispute[]             @relation("DisputeAssignedAdmin")
  tiakDeliveriesAsCustomer   TiakDelivery[]          @relation("TiakDeliveryCustomer")
  tiakDeliveriesAsCourier    TiakDelivery[]          @relation("TiakDeliveryCourier")
  tiakCourierProfile         TiakCourierProfile?
  tiakDeliveryEvents         TiakDeliveryEvent[]     @relation("TiakDeliveryEventActor")
  tiakPayouts               TiakPayout[]
  immoListings               ImmoListing[]
  immoPublisherMemberships    ImmoPublisherMember[]
  immoMonetizationPurchasesCreated ImmoMonetizationPurchase[] @relation("ImmoMonetizationCreatedBy")
}

model UserAddress {
  id        String   @id @default(cuid())
  userId    String
  label     String
  address   String
  city      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserRoleAssignment {
  id        String         @id @default(cuid())
  userId    String
  role      UserRoleType
  status    UserRoleStatus @default(ACTIVE)
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId, status])
}

model ImmoListing {
  id           String            @id @default(cuid())
  ownerId      String
  publisherId   String?
  title        String
  description  String
  listingType  ImmoListingType
  propertyType ImmoPropertyType
  priceCents   Int
  currency     String            @default("EUR")
  surfaceM2    Int
  rooms        Int?
  city         String
  country      String            @default("SN")
  addressHidden Boolean          @default(true)
  contactMode  ImmoContactMode   @default(INTERNAL_MESSAGE)
  imageUrls    String[]          @default([])
  status       ImmoListingStatus @default(DRAFT)
  isFeatured   Boolean           @default(false)
  featuredUntil DateTime?
  boostUntil   DateTime?
  monetizationUpdatedAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  publisher ImmoPublisher? @relation(fields: [publisherId], references: [id], onDelete: SetNull)
  monetizationPurchases ImmoMonetizationPurchase[]

  @@index([status, country, city])
  @@index([status, priceCents])
  @@index([status, surfaceM2])
  @@index([status, propertyType])
  @@index([ownerId, status, createdAt])
  @@index([publisherId, status])
  @@index([status, featuredUntil])
  @@index([status, boostUntil])
}

model ImmoPublisher {
  id        String             @id @default(cuid())
  type      ImmoPublisherType
  name      String
  slug      String             @unique
  status    ImmoPublisherStatus @default(ACTIVE)
  verified  Boolean            @default(false)
  country   String?
  city      String?
  logoUrl   String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  members  ImmoPublisherMember[]
  listings ImmoListing[]
  monetizationPurchases ImmoMonetizationPurchase[]

  @@index([status, type, createdAt])
  @@index([status, country, city])
  @@index([verified, status])
}

model ImmoPublisherMember {
  id          String                @id @default(cuid())
  publisherId String
  userId      String
  role        ImmoPublisherMemberRole @default(AGENT)
  status      UserRoleStatus        @default(ACTIVE)
  createdAt   DateTime              @default(now())

  publisher ImmoPublisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([publisherId, userId])
  @@index([publisherId, status])
  @@index([userId, status])
}

model ImmoMonetizationPurchase {
  id              String                         @id @default(cuid())
  listingId       String
  publisherId     String
  kind            ImmoMonetizationKind
  durationDays    Int
  amountCents     Int
  currency        String                         @default("XOF")
  status          ImmoMonetizationPurchaseStatus @default(PENDING)
  paymentLedgerId String                         @unique
  createdByUserId String
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  listing       ImmoListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  publisher     ImmoPublisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  paymentLedger PaymentLedger @relation(fields: [paymentLedgerId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("ImmoMonetizationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([status, kind])
  @@index([listingId, createdAt])
  @@index([publisherId, createdAt])
}

model SellerProfile {
  id               String       @id @default(cuid())
  userId           String       @unique
  displayName      String
  slug             String       @unique
  status           SellerStatus @default(PENDING)
  commissionRate   Int          @default(10)
  payoutAccountRef String?
  rating           Float        @default(5)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user      User             @relation(fields: [userId], references: [id])
  products  Product[]
  orders    Order[]
  payouts   Payout[]
  services  ServiceListing[]
  inquiries ProductInquiry[] @relation("InquirySeller")
  offers    ProductOffer[]   @relation("OfferSeller")
  reviews   ProductReview[]
}

model Product {
  id               String      @id @default(cuid())
  sellerId         String
  storeId          String?
  title            String
  slug             String
  description      String?
  priceCents       Int
  currency         String      @default("XOF")
  type             ProductType
  preorderLeadDays Int?
  dropshipSupplier String?
  stockQuantity    Int?        @default(0)
  pickupLocation   String?
  deliveryOptions  String?
  colorOptions     String[]    @default([])
  sizeOptions      String[]    @default([])
  attributes       Json?
  isActive         Boolean     @default(true)
  discountPercent  Int?
  boostStatus      BoostStatus @default(NONE)
  boostRequestedAt DateTime?
  boostedUntil     DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  seller     SellerProfile     @relation(fields: [sellerId], references: [id])
  store      Store?            @relation(fields: [storeId], references: [id])
  images     ProductImage[]
  orderItems OrderItem[]
  categories ProductCategory[]
  cartItems  UserCartItem[]
  favorites  Favorite[]
  inquiries  ProductInquiry[]
  offers     ProductOffer[]
  reviews    ProductReview[]

  @@unique([sellerId, slug])
  @@index([sellerId])
  @@index([storeId])
}

model Store {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  type        StoreType @default(MARKETPLACE)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products       Product[]
  categories     StoreCategory[]
  gpTrips        GpTrip[]
  prestaServices PrestaService[]
  prestaNeeds    PrestaNeed[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]        @relation("CategoryTree")
  products ProductCategory[]
  stores   StoreCategory[]
}

model StoreCategory {
  storeId    String
  categoryId String

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([storeId, categoryId])
  @@index([categoryId])
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Order {
  id              String         @id @default(cuid())
  userId          String
  sellerId        String?
  buyerName       String?
  buyerEmail      String?
  buyerPhone      String?
  shippingAddress String?
  shippingCity    String?
  paymentMethod   PaymentMethod?
  status          OrderStatus    @default(PENDING)
  subtotalCents   Int
  shippingCents   Int            @default(0)
  feesCents       Int            @default(0)
  totalCents      Int
  currency        String         @default("XOF")
  paymentStatus   PaymentStatus  @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id])
  seller         SellerProfile? @relation(fields: [sellerId], references: [id])
  items          OrderItem[]
  payment        Payment?
  payouts        Payout[]
  events         OrderEvent[]
  messages       OrderMessage[]
  tiakDeliveries TiakDelivery[]
  paymentLedgers PaymentLedger[]

  @@index([userId])
  @@index([sellerId])
  @@index([buyerEmail])
}

model OrderMessage {
  id         String    @id @default(cuid())
  orderId    String
  senderId   String?
  senderRole UserRole?
  body       String
  createdAt  DateTime  @default(now())

  order  Order @relation(fields: [orderId], references: [id])
  sender User? @relation(fields: [senderId], references: [id])

  @@index([orderId])
  @@index([senderId])
}

model OrderItem {
  id             String      @id @default(cuid())
  orderId        String
  productId      String
  quantity       Int         @default(1)
  unitPriceCents Int
  type           ProductType
  optionColor    String?
  optionSize     String?
  createdAt      DateTime    @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id          String         @id @default(cuid())
  orderId     String         @unique
  provider    String         @default("paydunya")
  providerRef String?
  amountCents Int
  currency    String         @default("XOF")
  status      PaymentStatus  @default(PENDING)
  method      PaymentMethod?
  splitMeta   Json?
  createdAt   DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model PaymentLedger {
  id               String                   @id @default(cuid())
  createdAt        DateTime                 @default(now())
  provider         String                   @default("PAYDUNYA")
  providerIntentId String?                  @unique
  orderId          String?
  contextType      PaymentLedgerContextType
  contextId        String
  amountTotalCents Int
  platformFeeCents Int
  payoutCents      Int
  currency         String                   @default("XOF")
  status           PaymentLedgerStatus      @default(INITIATED)

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  immoMonetizationPurchase ImmoMonetizationPurchase?

  @@unique([contextType, contextId])
  @@index([orderId])
}

model Payout {
  id          String       @id @default(cuid())
  sellerId    String
  orderId     String?
  amountCents Int
  currency    String       @default("XOF")
  status      PayoutStatus @default(PENDING)
  providerRef String?
  createdAt   DateTime     @default(now())

  seller SellerProfile @relation(fields: [sellerId], references: [id])
  order  Order?        @relation(fields: [orderId], references: [id])

  @@index([sellerId])
  @@index([orderId])
}

model GpTrip {
  id                     String          @id @default(cuid())
  transporterId          String
  storeId                String?
  originCity             String
  originAddress          String
  destinationCity        String
  destinationAddress     String
  airline                String
  flightNumber           String
  flightDate             DateTime
  deliveryStartAt        DateTime?
  deliveryEndAt          DateTime?
  availableKg            Int
  pricePerKgCents        Int
  currency               String          @default("XOF")
  maxPackages            Int?
  acceptedPaymentMethods PaymentMethod[] @default([])
  contactPhone           String?
  notes                  String?
  status                 GpTripStatus    @default(OPEN)
  isActive               Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  transporter User                @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  store       Store?              @relation(fields: [storeId], references: [id])
  reviews     TransporterReview[]
  bookings    GpTripBooking[]
  shipments   GpShipment[]

  @@index([transporterId])
  @@index([storeId])
  @@index([status])
  @@index([flightDate])
}

model GpTripBooking {
  id            String          @id @default(cuid())
  tripId        String
  customerId    String
  transporterId String
  status        GpBookingStatus @default(PENDING)
  requestedKg   Int
  packageCount  Int             @default(1)
  message       String?
  confirmedAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  trip        GpTrip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  customer    User         @relation("GpBookingCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  transporter User         @relation("GpBookingTransporter", fields: [transporterId], references: [id], onDelete: Cascade)
  shipment    GpShipment?

  @@unique([tripId, customerId])
  @@index([customerId, status, createdAt])
  @@index([transporterId, status, createdAt])
  @@index([tripId, status, createdAt])
}

model GpShipment {
  id            String           @id @default(cuid())
  bookingId     String?          @unique
  tripId        String?
  senderId      String?
  receiverId    String?
  transporterId String
  code          String           @unique
  fromCity      String
  toCity        String
  weightKg      Int
  status        GpShipmentStatus @default(DROPPED_OFF)
  note          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  booking     GpTripBooking?   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  trip        GpTrip?          @relation(fields: [tripId], references: [id], onDelete: SetNull)
  sender      User?            @relation("GpShipmentSender", fields: [senderId], references: [id], onDelete: SetNull)
  receiver    User?            @relation("GpShipmentReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
  transporter User             @relation("GpShipmentTransporter", fields: [transporterId], references: [id], onDelete: Cascade)
  events      GpShipmentEvent[]

  @@index([transporterId, status, updatedAt])
  @@index([senderId, status, updatedAt])
  @@index([receiverId, status, updatedAt])
  @@index([tripId, status])
}

model GpShipmentEvent {
  id         String           @id @default(cuid())
  shipmentId String
  status     GpShipmentStatus
  note       String?
  proofUrl   String?
  proofType  String?
  actorId    String
  createdAt  DateTime         @default(now())

  shipment GpShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  actor    User       @relation("GpShipmentEventActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
  @@index([actorId, createdAt])
}

model ServiceListing {
  id          String   @id @default(cuid())
  sellerId    String
  title       String
  description String?
  priceCents  Int
  currency    String   @default("XOF")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller   SellerProfile    @relation(fields: [sellerId], references: [id])
  bookings ServiceBooking[]

  @@index([sellerId])
}

model ServiceBooking {
  id          String        @id @default(cuid())
  serviceId   String
  customerId  String
  status      BookingStatus @default(PENDING)
  scheduledAt DateTime?
  priceCents  Int
  currency    String        @default("XOF")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  service  ServiceListing @relation(fields: [serviceId], references: [id])
  customer User           @relation(fields: [customerId], references: [id])

  @@index([serviceId])
  @@index([customerId])
}

model PrestaService {
  id                     String          @id @default(cuid())
  providerId             String
  storeId                String?
  title                  String
  description            String?
  category               String?
  city                   String?
  basePriceCents         Int
  currency               String          @default("XOF")
  contactPhone           String?
  acceptedPaymentMethods PaymentMethod[] @default([])
  isActive               Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  provider  User             @relation(fields: [providerId], references: [id], onDelete: Cascade)
  store     Store?           @relation(fields: [storeId], references: [id])
  bookings  PrestaBooking[]
  proposals PrestaProposal[]

  @@index([providerId])
  @@index([storeId])
  @@index([isActive, createdAt])
}

model PrestaBooking {
  id            String              @id @default(cuid())
  serviceId     String
  customerId    String
  providerId    String
  orderId       String?             @unique
  proposalId    String?             @unique
  status        PrestaBookingStatus @default(PENDING)
  quantity      Int                 @default(1)
  message       String?
  totalCents    Int
  currency      String              @default("XOF")
  paymentMethod PaymentMethod?
  confirmedAt   DateTime?
  paidAt        DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  service        PrestaService   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customer       User            @relation("PrestaBookingCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  provider       User            @relation("PrestaBookingProvider", fields: [providerId], references: [id], onDelete: Cascade)
  proposal       PrestaProposal? @relation("PrestaProposalBooking", fields: [proposalId], references: [id], onDelete: SetNull)
  linkedProposal PrestaProposal? @relation("PrestaBookingByProposalId")
  reviews        Review[]
  payout         PrestaPayout?

  @@index([serviceId, status, createdAt])
  @@index([customerId, status, createdAt])
  @@index([providerId, status, createdAt])
  @@index([orderId])
}

model PrestaNeed {
  id            String           @id @default(cuid())
  customerId    String
  storeId       String?
  title         String
  description   String
  city          String?
  area          String?
  budgetCents   Int?
  currency      String           @default("XOF")
  preferredDate DateTime?
  status        PrestaNeedStatus @default(OPEN)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  customer  User             @relation("PrestaNeedCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  store     Store?           @relation(fields: [storeId], references: [id])
  proposals PrestaProposal[]

  @@index([status, createdAt])
  @@index([customerId, createdAt])
  @@index([storeId, status])
}

model PrestaProposal {
  id         String               @id @default(cuid())
  needId     String
  serviceId  String
  providerId String
  bookingId  String?              @unique
  message    String?
  status     PrestaProposalStatus @default(PENDING)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  need              PrestaNeed     @relation(fields: [needId], references: [id], onDelete: Cascade)
  service           PrestaService  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  provider          User           @relation("PrestaProposalProvider", fields: [providerId], references: [id], onDelete: Cascade)
  booking           PrestaBooking? @relation("PrestaBookingByProposalId", fields: [bookingId], references: [id], onDelete: SetNull)
  linkedFromBooking PrestaBooking? @relation("PrestaProposalBooking")

  @@unique([needId, providerId])
  @@index([needId, status, createdAt])
  @@index([serviceId])
  @@index([providerId, createdAt])
}

model PrestaPayout {
  id                  String             @id @default(cuid())
  createdAt           DateTime           @default(now())
  bookingId           String             @unique
  providerId          String
  amountTotalCents    Int
  platformFeeCents    Int
  providerPayoutCents Int
  currency            String
  status              PrestaPayoutStatus @default(PENDING)

  booking  PrestaBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider User          @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@index([providerId, status, createdAt])
}

model Review {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  authorId     String
  targetUserId String
  bookingId    String
  rating       Int
  comment      String?

  author     User          @relation("PrestaReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetUser User          @relation("PrestaReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  booking    PrestaBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([authorId, bookingId])
}

model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  proofUrl  String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model TiakCourierProfile {
  id             String   @id @default(cuid())
  courierId      String   @unique
  isActive       Boolean  @default(true)
  cities         String[] @default([])
  areas          String[] @default([])
  vehicleType    String?
  maxWeightKg    Int?
  availableHours String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  courier User @relation(fields: [courierId], references: [id], onDelete: Cascade)

  @@index([isActive, updatedAt])
}

model TiakDelivery {
  id             String             @id @default(cuid())
  customerId     String
  courierId      String?
  status         TiakDeliveryStatus @default(REQUESTED)
  pickupAddress  String
  dropoffAddress String
  note           String?
  priceCents     Int?
  currency       String             @default("XOF")
  paymentMethod  PaymentMethod?
  orderId        String?
  paymentStatus  PaymentStatus?     @default(PENDING)
  paidAt         DateTime?
  assignedAt     DateTime?
  assignExpiresAt DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  customer User                @relation("TiakDeliveryCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  courier  User?               @relation("TiakDeliveryCourier", fields: [courierId], references: [id], onDelete: SetNull)
  order    Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  events   TiakDeliveryEvent[]
  payout   TiakPayout?

  @@index([customerId, status, createdAt])
  @@index([courierId, status, createdAt])
  @@index([status, createdAt])
  @@index([orderId])
}

model TiakDeliveryEvent {
  id         String             @id @default(cuid())
  deliveryId String
  status     TiakDeliveryStatus
  note       String?
  proofUrl   String?
  createdAt  DateTime           @default(now())
  actorId    String

  delivery TiakDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  actor    User         @relation("TiakDeliveryEventActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([deliveryId, createdAt])
  @@index([actorId, createdAt])
}

model TiakPayout {
  id                 String           @id @default(cuid())
  createdAt          DateTime         @default(now())
  deliveryId         String           @unique
  courierId          String
  amountTotalCents   Int
  platformFeeCents   Int
  courierPayoutCents Int
  currency           String           @default("XOF")
  status             TiakPayoutStatus @default(PENDING)

  delivery TiakDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  courier  User         @relation(fields: [courierId], references: [id], onDelete: Restrict)

  @@index([courierId, status, createdAt])
}

model Dispute {
  id              String             @id @default(cuid())
  vertical        String
  referenceId     String
  contextType     DisputeContextType @default(SHOP_ORDER)
  contextId       String             @default("")
  reason          String
  description     String?
  status          DisputeStatus      @default(OPEN)
  openedById      String
  assignedAdminId String?
  resolutionNote  String?
  resolvedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  openedBy      User  @relation("DisputeOpenedBy", fields: [openedById], references: [id], onDelete: Cascade)
  assignedAdmin User? @relation("DisputeAssignedAdmin", fields: [assignedAdminId], references: [id], onDelete: SetNull)

  @@unique([contextType, contextId, status])
  @@index([openedById, status, createdAt])
  @@index([assignedAdminId])
  @@index([referenceId])
  @@index([vertical, status])
  @@index([contextType, contextId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
}

model ProductReview {
  id           String   @id @default(cuid())
  productId    String
  sellerId     String
  buyerId      String
  rating       Int
  sellerRating Int?
  title        String?
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller  SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyer   User          @relation("ProductReviewBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([productId, buyerId])
  @@index([productId, createdAt])
  @@index([sellerId, createdAt])
  @@index([buyerId, createdAt])
}

model TransporterReview {
  id            String   @id @default(cuid())
  transporterId String
  reviewerId    String
  tripId        String
  rating        Int
  title         String?
  comment       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transporter User   @relation("TransporterReviewTransporter", fields: [transporterId], references: [id], onDelete: Cascade)
  reviewer    User   @relation("TransporterReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  trip        GpTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, reviewerId])
  @@index([transporterId, createdAt])
  @@index([reviewerId, createdAt])
  @@index([tripId, createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model KycSubmission {
  id               String    @id @default(cuid())
  userId           String
  targetRole       KycRole
  status           KycStatus @default(PENDING)
  reviewedById     String?
  reviewedAt       DateTime?
  reviewReason     String?
  docIdUrl         String?
  driverLicenseUrl String?
  proofAddressUrl  String?
  selfieUrl        String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user       User  @relation("KycSubmissionUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("KycReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([targetRole])
  @@index([reviewedById])
}

model ProductInquiry {
  id               String        @id @default(cuid())
  productId        String
  buyerId          String
  sellerId         String
  status           InquiryStatus @default(OPEN)
  lastMessageAt    DateTime      @default(now())
  buyerLastReadAt  DateTime?
  sellerLastReadAt DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  product  Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer    User                    @relation("InquiryBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   SellerProfile           @relation("InquirySeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages ProductInquiryMessage[]
  offers   ProductOffer[]

  @@unique([productId, buyerId])
  @@index([sellerId, status, lastMessageAt])
  @@index([buyerId, status, lastMessageAt])
}

model ProductInquiryMessage {
  id        String   @id @default(cuid())
  inquiryId String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  inquiry ProductInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  sender  User           @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
  @@index([senderId])
}

model ProductOffer {
  id          String      @id @default(cuid())
  inquiryId   String
  productId   String
  buyerId     String
  sellerId    String
  quantity    Int         @default(1)
  amountCents Int
  currency    String      @default("XOF")
  note        String?
  status      OfferStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  resolvedAt  DateTime?

  inquiry   ProductInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer     User           @relation("OfferBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller    SellerProfile  @relation("OfferSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  cartItems UserCartItem[]

  @@index([inquiryId, createdAt])
  @@index([sellerId, status, createdAt])
  @@index([buyerId, status, createdAt])
}

model UserCart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items UserCartItem[]

  @@index([updatedAt])
}

model UserCartItem {
  id          String   @id @default(cuid())
  cartId      String
  lineId      String
  productId   String
  offerId     String?
  quantity    Int      @default(1)
  optionColor String?
  optionSize  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cart    UserCart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  offer   ProductOffer? @relation(fields: [offerId], references: [id], onDelete: SetNull)

  @@unique([cartId, lineId])
  @@index([cartId])
  @@index([productId])
  @@index([offerId])
}
